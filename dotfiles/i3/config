
set $mod Mod4
##########################################################		       
#		      STARTUP				 #
##########################################################
#SYS
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id nm-applet 
#USER
exec_always --no-startup-id feh --bg-fill /etc/nixos/media/cottage.jpg
exec_always --no-startup-id /etc/nixos/dotfiles/polybar/launch.sh
#APPS
exec --no-startup-id librewolf
exec --no-startup-id kitty
