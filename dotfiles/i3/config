# GAPS
gaps inner 10
#gaps outer 3

gaps top 4
gaps bottom 0
gaps left 6
gaps right 6

# BORDERS
default_border pixel 1
default_floating_border pixel 1
# FOCUSED			BORDER  BACKGR  TEXT    INDICAT #CHILD-BORDER
client.focused			#f5f5f5 #f5f5f5 #444444 #f5f5f5 
# UNFOCUSED 
client.unfocused		#F2E2A2 #F2E2A2 #000000 #d5c4a1
